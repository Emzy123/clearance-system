# Production Environment Variables for Render Deployment
NODE_ENV=production
PORT=5000

# MongoDB Database Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clearance-system?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# Frontend URL (Update with your Render frontend URL)
CLIENT_URL=https://your-frontend-app.onrender.com

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
