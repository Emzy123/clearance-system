{
  "services": [
    {
      "type": "web",
      "name": "clearance-system-api",
      "runtime": "node",
      "plan": "free",
      "rootDir": "server",
      "buildCommand": "npm install",
      "startCommand": "npm start",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production",
          "sync": true
        },
        {
          "key": "PORT",
          "value": "5000",
          "sync": true
        },
        {
          "key": "MONGODB_URI",
          "value": "mongodb+srv://clearance-admin:YOUR_PASSWORD@clearance-system-cluster.mongodb.net/clearance-system?retryWrites=true&w=majority",
          "sync": false
        },
        {
          "key": "JWT_SECRET",
          "value": {
            "generateValue": true,
            "length": 64
          },
          "sync": true
        },
        {
          "key": "JWT_EXPIRE",
          "value": "7d",
          "sync": true
        },
        {
          "key": "CLIENT_URL",
          "value": "https://clearance-system-frontend.onrender.com",
          "sync": true
        }
      ]
    },
    {
      "type": "web",
      "name": "clearance-system-frontend",
      "runtime": "static",
      "plan": "free",
      "rootDir": "client/dist",
      "buildCommand": "cd client && npm install && npm run build",
      "envVars": [
        {
          "key": "VITE_API_URL",
          "value": "https://clearance-system-api.onrender.com/api",
          "sync": true
        },
        {
          "key": "VITE_SOCKET_URL",
          "value": "https://clearance-system-api.onrender.com",
          "sync": true
        }
      ]
    }
  ]
}