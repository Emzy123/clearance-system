{
  "name": "clearance-system",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm-run-all build:server build:client",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "demo:seed": "npm --prefix server run seed",
    "demo:reset": "npm --prefix server run seed",
    "test:server": "npm --prefix server run test",
    "test:smoke": "node scripts/smoke-check.mjs",
    "check": "npm-run-all test:server build test:smoke",
    "start:prod": "npm --prefix server run start:prod"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

